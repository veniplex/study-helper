# --- Required ---
# PostgreSQL connection string (pgvector image recommended)
DATABASE_URL=postgres://study:study@localhost:5432/study

# Public base URL of the app (used for auth callbacks, emails, push)
APP_URL=http://localhost:3000

# Secret for auth/session signing — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me

# Key for encrypting stored secrets (user AI keys, resource notes)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me

# --- Optional ---
# Which published image tag to run. Defaults to :latest (newest release).
# Pin a specific version for reproducible deploys, e.g. STUDYHELPER_VERSION=1.0.0
# STUDYHELPER_VERSION=latest

# Where docker-compose stores persistent data on the HOST (database +
# uploaded files). Defaults to ./data next to docker-compose.yml. Use an
# absolute path to put it elsewhere, e.g. on a separate disk:
# DATA_DIR=/srv/studyhelper/data

# Server timezone. Event times entered in the UI, reminder emails/pushes and
# the daily plan all use this timezone — set it to where your users live.
# Docker containers default to UTC, which shifts all times for German users!
# TZ=Europe/Berlin


# Staging directory for resumable (tus) uploads of very large files. Files live
# here only until they are moved into storage, then are deleted. Defaults to
# ./data/tus-incoming; put it on a persistent volume so an interrupted upload can
# resume after a restart.
# TUS_DIR=/data/tus-incoming

# Object storage for uploaded files. Default is local disk (the uploads volume
# above). For large multi-GB modules or multi-node setups, use S3 or any
# S3-compatible service (AWS S3, MinIO, Cloudflare R2). See docs/self-hosting.md.
# STORAGE_DRIVER=s3
# S3_BUCKET=study-helper
# S3_REGION=eu-central-1
# S3_ENDPOINT=https://s3.example.com     # only for S3-compatible services (MinIO/R2)
# S3_FORCE_PATH_STYLE=true               # required by MinIO / some endpoints
# S3_KEY_PREFIX=study-helper             # optional object key prefix
# Credentials via the standard AWS chain:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...


# Demo data on startup: creates admin@example.com / admin-test-1234 (admin)
# and user@example.com / user-test-1234, each with sample study content.
# Runs once (skipped if the accounts exist). Never enable in production.
# SEED_TEST_DATA=true

# Everything else (SMTP, AI providers, OIDC, branding, limits)
# is configured in the admin panel after first login.

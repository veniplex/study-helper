# --- Required ---
# PostgreSQL connection string (pgvector image recommended)
DATABASE_URL=postgres://study:study@localhost:5432/study

# Public base URL of the app (used for auth callbacks, emails, push)
APP_URL=http://localhost:3000

# Secret for auth/session signing — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me

# Key for encrypting stored secrets (user AI keys, resource notes)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me

# --- Optional ---
# Everything else (SMTP, AI providers, OIDC, branding, limits)
# is configured in the admin panel after first login.
